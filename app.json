{
  "expo": {
    "name": "Hirvia",
    "slug": "hirvia",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "hirvia",
    "icon": "./assets/branding/hirvia-icon-final.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/branding/hirvia-icon-final.png"
    },
    "splash": {
      "image": "./assets/branding/hirvia-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hirvia.ai",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 2,
      "package": "com.hirvia.ai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/hirvia-icon-final.png",
        "backgroundColor": "#0B1220"
      }
    },
    "plugins": [
      "./plugins/withAndroidIapFlavor",
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "37c12df9-d5cb-4d21-8a5f-83cebb2c0b39"
      }
    },
    "owner": "smtycl"
  }
}
