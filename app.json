{
  "expo": {
    "name": "Hirvia",
    "slug": "hirvia",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "hirvia",
    "icon": "./assets/branding/hirvia-icon-final.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/branding/hirvia-icon-final.png"
    },
    "splash": {
      "image": "./assets/branding/hirvia-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hirvia.ai"
    },
    "android": {
      "package": "com.hirvia.ai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/hirvia-icon-final.png",
        "backgroundColor": "#0B1220"
      }
    },
    "plugins": [
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "50b50267-e974-4c60-9645-0b05caa9a501"
      }
    },
    "owner": "simic52"
  }
}
